{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NAPLAN Cohort Tracker",
  "version": "1.0.1",
  "identifier": "com.dandsarmstrong.naplancohorttracker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NAPLAN Cohort Tracker",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Education",
    "shortDescription": "On-device NAPLAN cohort analysis",
    "longDescription": "NAPLAN Cohort Tracker analyses NAPLAN SSSR data on-device: participation, proficiency, equity, skill gaps and the Year 7 to Year 9 matched-cohort value-add. Local-only; no student data leaves the machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mrdavearms/naplan-cohort-tracker-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxMzJDNEQyQTk2QzUwRDgKUldUWVVHeXAwc1F5OGZGd2kyd0RJaGFnaGlONE80b1VTSXVKUk05eVNlNmFyOHl6bGdTMytqeHAK"
    }
  }
}
